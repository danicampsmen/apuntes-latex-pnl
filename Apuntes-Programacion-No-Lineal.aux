\def\@LN@column{1}
\@writefile{lof}{\contentsline {figure}{\numberline {7.2}{\ignorespaces Tres iteraciones del método de planos cortantes para la función $f$ en el conjunto $D = [0, a]$. Se tiene que $x^{k+1}$ es el minimizador de la aproximación $\mitpsi _k$ en $D$. Después de cada iteración, un plano cortante más es introducido en la aproximación: $\mitpsi _{k+1}(x) = \max \{\mitpsi _k(x), f(x^{k+1}) + \interno  {y^{k+1}}{x - x^{k+1}}\}$, $y^{k+1} \in \partial f(x^{k+1})$.}}{203}{figure.7.2}\protected@file@percent }
\newlabel{v2:fig:5.2.2}{{7.2}{203}{Tres iteraciones del método de planos cortantes para la función $f$ en el conjunto $D = [0, a]$. Se tiene que $x^{k+1}$ es el minimizador de la aproximación $\psi _k$ en $D$. Después de cada iteración, un plano cortante más es introducido en la aproximación: $\psi _{k+1}(x) = \max \{\psi _k(x), f(x^{k+1}) + \interno {y^{k+1}}{x - x^{k+1}}\}$, $y^{k+1} \in \partial f(x^{k+1})$}{figure.7.2}{}}
\newlabel{v2:fig:5.2.2@cref}{{[figure][2][7]7.2}{[1][203][]203}{}{}{}}
\def\@LN@column{1}
\@writefile{lof}{\contentsline {figure}{\numberline {7.3}{\ignorespaces La iteración del método de planos cortantes puede generar $x^{k+1}$ para el cual la distancia a la solución y el valor de la función objetivo aumentan en comparación con el iterado anterior $x^k$.}}{204}{figure.7.3}\protected@file@percent }
\newlabel{v2:fig:5.2.3}{{7.3}{204}{La iteración del método de planos cortantes puede generar $x^{k+1}$ para el cual la distancia a la solución y el valor de la función objetivo aumentan en comparación con el iterado anterior $x^k$}{figure.7.3}{}}
\newlabel{v2:fig:5.2.3@cref}{{[figure][3][7]7.3}{[1][204][]204}{}{}{}}
\newlabel{v2:thm:5.2.1}{{7.3}{204}{Convergencia del método de planos cortantes}{theorem.7.3}{}}
\newlabel{v2:thm:5.2.1@cref}{{[theorem][3][7]7.3}{[1][204][]204}{}{}{}}
