\@writefile{lof}{\contentsline {figure}{\numberline {8.9}{\ignorespaces Solución de subproblemas de regiones de confianza (son mostradas curvas de nivel de un minimizador irrestricto de $\mitpsi _k$, y la posición de la solución $\tilde {x}^k$ de \eqref  {v2:eq:3.84}, dependiendo del valor de $\mitdelta _k$).}}{122}{figure.8.9}\protected@file@percent }
\newlabel{v2:fig:3.3.3}{{8.9}{122}{Solución de subproblemas de regiones de confianza (son mostradas curvas de nivel de un minimizador irrestricto de $\psi _k$, y la posición de la solución $\tilde {x}^k$ de \eqref {v2:eq:3.84}, dependiendo del valor de $\delta _k$)}{figure.8.9}{}}
\newlabel{v2:fig:3.3.3@cref}{{[figure][9][8]8.9}{[1][122][]122}{}{}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {8.10}{\ignorespaces La curva de soluciones $d(\mitmu )$ de subproblemas de regiones de confianza para $\mitmu \in [0, +\infty )$: el paso de Newton corresponde a $d(0)$; para $\mitmu $ grande, el paso se vuelve casi en la dirección del anti-gradiente (la variación de $\mitmu $ en $[0, +\infty )$ corresponde a la variación inversa del radio $\mitdelta $).}}{122}{figure.8.10}\protected@file@percent }
\newlabel{v2:fig:3.3.4}{{8.10}{122}{La curva de soluciones $d(\mu )$ de subproblemas de regiones de confianza para $\mu \in [0, +\infty )$: el paso de Newton corresponde a $d(0)$; para $\mu $ grande, el paso se vuelve casi en la dirección del anti-gradiente (la variación de $\mu $ en $[0, +\infty )$ corresponde a la variación inversa del radio $\delta $)}{figure.8.10}{}}
\newlabel{v2:fig:3.3.4@cref}{{[figure][10][8]8.10}{[1][122][]122}{}{}{}}
