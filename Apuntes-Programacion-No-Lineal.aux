\@writefile{lof}{\contentsline {figure}{\numberline {11.2}{\ignorespaces Tres iteraciones del método de planos cortantes para la función $f$ en el conjunto $D = [0, a]$. Se tiene que $x^{k+1}$ es el minimizador de la aproximación $\mitpsi _k$ en $D$. Después de cada iteración, un plano cortante más es introducido en la aproximación: $\mitpsi _{k+1}(x) = \max \{\mitpsi _k(x), f(x^{k+1}) + \interno  {y^{k+1}}{x - x^{k+1}}\}$, $y^{k+1} \in \partial f(x^{k+1})$.}}{228}{figure.11.2}\protected@file@percent }
\newlabel{v2:fig:5.2.2}{{11.2}{228}{Tres iteraciones del método de planos cortantes para la función $f$ en el conjunto $D = [0, a]$. Se tiene que $x^{k+1}$ es el minimizador de la aproximación $\psi _k$ en $D$. Después de cada iteración, un plano cortante más es introducido en la aproximación: $\psi _{k+1}(x) = \max \{\psi _k(x), f(x^{k+1}) + \interno {y^{k+1}}{x - x^{k+1}}\}$, $y^{k+1} \in \partial f(x^{k+1})$}{figure.11.2}{}}
\newlabel{v2:fig:5.2.2@cref}{{[figure][2][11]11.2}{[1][228][]228}{}{}{}}
\def\@LN@column{1}
\@writefile{lof}{\contentsline {figure}{\numberline {11.3}{\ignorespaces La iteración del método de planos cortantes puede generar $x^{k+1}$ para el cual la distancia a la solución y el valor de la función objetivo aumentan en comparación con el iterado anterior $x^k$.}}{229}{figure.11.3}\protected@file@percent }
\newlabel{v2:fig:5.2.3}{{11.3}{229}{La iteración del método de planos cortantes puede generar $x^{k+1}$ para el cual la distancia a la solución y el valor de la función objetivo aumentan en comparación con el iterado anterior $x^k$}{figure.11.3}{}}
\newlabel{v2:fig:5.2.3@cref}{{[figure][3][11]11.3}{[1][229][]229}{}{}{}}
